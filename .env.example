# ═══════════════════════════════════════════════════════════
# HYDRA INTEL — Environment Variables
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════

# ── GitHub ──
GITHUB_TOKEN=

# ── Reddit ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Infrastructure ──
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
ZOOMEYE_API_KEY=
NETLAS_API_KEY=
SECURITYTRAILS_API_KEY=
IPINFO_API_KEY=

# ── Threat Intel ──
VIRUSTOTAL_API_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=
VULNERS_API_KEY=
INTELX_API_KEY=
NVD_API_KEY=

# ── Telegram ──
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=

# ── Social Media ──
SOCIAL_SEARCHER_API_KEY=

# ── Leak Detection ──
HIBP_API_KEY=
DEHASHED_EMAIL=
DEHASHED_API_KEY=
SNUSBASE_API_KEY=
LEAKCHECK_API_KEY=
LEAKLOOKUP_API_KEY=

# ── MISP / OpenCTI ──
MISP_URL=
MISP_KEY=
OPENCTI_URL=
OPENCTI_TOKEN=

# ── Hydra Settings ──
HYDRA_DB_TYPE=sqlite
HYDRA_DB_PATH=intel.db
HYDRA_LOG_LEVEL=INFO
HYDRA_RATE_LIMIT=1.0
HYDRA_MAX_RESULTS=50
TOR_ENABLED=true
